{
  "name": "roman",
  "version": "0.1.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gameroman/roman.git"
  },
  "bin": {
    "roman": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "u": "bun run --sequential format lint build test",
    "test": "bun test --dots",
    "test:run": "bun run --sequential test:check test:update",
    "test:check": "SKIP_SNAPSHOTS=1 bun run test",
    "test:update": "bun test --dots -u",
    "lint": "oxlint",
    "format": "oxfmt",
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@gameroman/config": "^0.0.6",
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.3.11"
  }
}
